# Public ports on host
HTTP_PORT=80
POSTGRES_HOST_PORT=54328

# Postgres container credentials
POSTGRES_DB=dev
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# MinIO root credentials
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=supersecretpassword

# MinIO bucket name (used by s3-init)
AWS_BUCKET=social-network-media

# Mercure
MERCURE_JWT_SECRET=f6a74b5282c858ad2f23fa140e32e15824546fdf7be4b34ea3e06a4a0d51d7de
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://hardev.eu/.well-known/mercure
MERCURE_EXTRA_DIRECTIVES=anonymous\ncors_origins *\n

# Build args
INSTALL_XDEBUG=0
