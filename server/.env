### APP ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=demo_app_secret_change_me

DEFAULT_URI=http://localhost:8080

### DATABASE ###
POSTGRES_DB=dev
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST_PORT=54328

DATABASE_URL="postgresql://app:app@postgres:5432/dev?serverVersion=16&charset=utf8"

### MERCURE ###
MERCURE_JWT_SECRET=demo_mercure_secret_change_melnlknklnklnsdfnklsndf
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:8080/.well-known/mercure

CORS_ALLOW_ORIGIN='^http?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

### MINIO / S3 ###
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=supersecretpassword

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

AWS_ACCESS_KEY_ID=anton
AWS_SECRET_ACCESS_KEY=antonsuper
AWS_BUCKET=social-network-media
AWS_REGION=us-east-1
AWS_ENDPOINT=http://s3:9000
AWS_PUBLIC_ENDPOINT=/media

### MAIL ###
MAILER_DSN=smtp://mailer:1025
MAIL_FROM="Social Network <no-reply@localhost>"

### MESSENGER ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

### NGINX (host binding) ###
NGINX_BIND_IP=127.0.0.1
HTTP_PORT=8080

### BUILD ###
INSTALL_XDEBUG=0
